# MongoDB connection string (MongoDB Atlas free tier works great)
# Get one at https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb://localhost:27017/interview-tracker

# JWT secret - generate a long random string for production
# e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string

# JWT token expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Frontend URL for CORS (update when deployed)
CLIENT_URL=http://localhost:5173

# Node environment
NODE_ENV=development
